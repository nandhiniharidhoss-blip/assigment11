<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Search Box</title>

<style>
body{
    margin:0;
    padding:0;
    font-family:Arial, sans-serif;
    background:#fff;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.container{
    text-align:center;
}

h1{
    color:#4285F4;
    font-size:55px;
    margin-bottom:20px;
}

input{
    width:500px;
    max-width:90%;
    padding:15px;
    border:1px solid #ccc;
    border-radius:30px;
    font-size:18px;
    outline:none;
}

button{
    margin-top:20px;
    padding:12px 35px;
    border:none;
    border-radius:25px;
    background:#4285F4;
    color:white;
    font-size:16px;
    cursor:pointer;
}

button:hover{
    background:#3367d6;
}
</style>
</head>

<body>

<div class="container">

<h1>Search</h1>

<form action="https://formspree.io/f/mwvdyvdo" method="POST">

<input
type="text"
name="Search Text"
placeholder="Enter your search..."
required>

<br>

<button type="submit">Search</button>

</form>

</div>

</body>
</html>
